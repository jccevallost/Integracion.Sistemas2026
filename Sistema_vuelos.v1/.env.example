# ── Variables requeridas por docker-compose.yml ──────────────────
# Copiar a .env y completar antes de ejecutar `docker compose up`

# PostgreSQL / Supabase
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&sslmode=require"

# JWT (genera uno con: openssl rand -hex 64)
JWT_SECRET=your-256-bit-hex-secret
JWT_ISSUER=vuelos-api
JWT_AUDIENCE=vuelos-client
JWT_EXPIRES_IN=2h

# Entorno
NODE_ENV=production

# URL del frontend (opcional — para CORS del gateway)
FRONTEND_URL=https://tu-frontend.com
