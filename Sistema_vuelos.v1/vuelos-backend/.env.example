# ──────────────────────────────────────────────────────────────
#  BASE DE DATOS POR MICROSERVICIO (Supabase)
# ──────────────────────────────────────────────────────────────
AUTH_DATABASE_URL="postgresql://USER:PASS@HOST:5432/postgres?sslmode=require"
CATALOG_DATABASE_URL="postgresql://USER:PASS@HOST:5432/postgres?sslmode=require"
FLIGHTS_DATABASE_URL="postgresql://USER:PASS@HOST:6543/postgres?pgbouncer=true&sslmode=require"
BOOKING_DATABASE_URL="postgresql://USER:PASS@HOST:5432/postgres?sslmode=require"
PAYMENTS_DATABASE_URL="postgresql://USER:PASS@HOST:5432/postgres?sslmode=require"
ADMIN_DATABASE_URL="postgresql://USER:PASS@HOST:5432/postgres?sslmode=require"

# Alias genérico — apunta a flights-db (base con datos) para schema monolítico
DATABASE_URL="${FLIGHTS_DATABASE_URL}"

# ──────────────────────────────────────────────────────────────
#  SERVER CONFIG
# ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# ──────────────────────────────────────────────────────────────
#  JWT  (genera con: openssl rand -hex 64)
# ──────────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-hex-secret
JWT_ISSUER=vuelos-api
JWT_AUDIENCE=vuelos-client
JWT_EXPIRES_IN=2h

# ──────────────────────────────────────────────────────────────
#  COMUNICACIÓN INTER-SERVICIO  (genera con: openssl rand -hex 32)
# ──────────────────────────────────────────────────────────────
INTERNAL_API_KEY=your-internal-api-key-min-32-chars

# URLs de servicios — solo para desarrollo local fuera de Docker
AUTH_SERVICE_URL=http://localhost:3001
FLIGHTS_SERVICE_URL=http://localhost:3003

# ──────────────────────────────────────────────────────────────
#  PUERTOS (desarrollo local)
# ──────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3002
FLIGHTS_SERVICE_PORT=3003
GRPC_PORT=50051
BOOKING_SERVICE_PORT=3004
PAYMENTS_SERVICE_PORT=3005
ADMIN_SERVICE_PORT=3006
